# Root-level configuration for docker-compose.
# Copy to `.env` and adjust to override the defaults baked into docker-compose.yml.

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simpleinvoice
DB_PORT=5432

# Backend
BACKEND_PORT=3001
# REQUIRED. Compose has no fallback — it refuses to start if this is blank.
# This is a dev-only placeholder; generate your own, e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-only-secret-change-me-before-deploying
JWT_EXPIRES_IN=3600
FRONTEND_ORIGIN=http://localhost:3000

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:3001
