# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/simpleinvoice?schema=public"

# ---- Auth / JWT ----
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN=3600            # access-token lifetime in seconds (default 3600 if unset)

# ---- CORS ----
FRONTEND_ORIGIN="http://localhost:3000"   # allowed CORS origin for the SPA

# ---- Server ----
PORT=3001
